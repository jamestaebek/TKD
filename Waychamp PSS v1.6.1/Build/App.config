<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
      <section name="JiJingTaekwondo.ConfigFile.StrengthTuning" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
      <section name="JiJingTaekwondo.ConfigFile.OvrUrl" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
      <section name="JiJingTaekwondo.ConfigFile.JudgePoints" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
      <section name="JiJingTaekwondo.ConfigFile.SoundFilePath" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
      <section name="JiJingTaekwondo.ConfigFile.RulesData" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
      <section name="JiJingTaekwondo.ConfigFile.Key" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
      <section name="JiJingTaekwondo.ConfigFile.Equipment" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
      <section name="JiJingTaekwondo.ConfigFile.Connect" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
      <section name="JiJingTaekwondo.Config.Login.login" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
    </sectionGroup>
    <!--<section name="log4net" type="System.Configuration.IgnoreSectionHandler"/>-->
    <section name="unity" type="Microsoft.Practices.Unity.Configuration.UnityConfigurationSection, Microsoft.Practices.Unity.Configuration"/>
  </configSections>
  <unity xmlns="http://schemas.microsoft.com/practces/2010/unity">
    <typeAliases>
      <typeAlias alias="IAthleteService" type="JiJingTaekwondo.IMatchService.IAthleteService,JiJingTaekwondo"/>
      <typeAlias alias="AthleteService" type="JiJingTaekwondo.MatchService.AthleteService,JiJingTaekwondo"/>
      <typeAlias alias="IMatchPortPara" type="JiJingTaekwondo.IMatchService.IMatchPortPara,JiJingTaekwondo"/>
      <typeAlias alias="MatchPortPara" type="JiJingTaekwondo.MatchService.MatchPortPara,JiJingTaekwondo"/>
      <typeAlias alias="IMatchManagerService" type="JiJingTaekwondo.IMatchService.IMatchManagerService,JiJingTaekwondo"/>
      <typeAlias alias="MatchManagerService" type="JiJingTaekwondo.MatchService.MatchManagerService,JiJingTaekwondo"/>
      <typeAlias alias="IFunctionManagerService" type="JiJingTaekwondo.IMatchService.IFunctionManagerService,JiJingTaekwondo"/>
      <typeAlias alias="FunctionManagerService" type="JiJingTaekwondo.MatchService.FunctionManagerService,JiJingTaekwondo"/>
      <typeAlias alias="IMatchResultService" type="JiJingTaekwondo.IMatchService.IMatchResultService,JiJingTaekwondo"/>
      <typeAlias alias="MatchResultService" type="JiJingTaekwondo.MatchService.MatchResultService,JiJingTaekwondo"/>
      <typeAlias alias="MatchService" type="JiJingTaekwondo.MatchService.MatchService,JiJingTaekwondo"/>
      <typeAlias alias="lMatchService" type="JiJingTaekwondo.IMatchService.lMatchService,JiJingTaekwondo"/>
      <typeAlias alias="IStageManageService" type="JiJingTaekwondo.IMatchService.IStageManageService,JiJingTaekwondo"/>
      <typeAlias alias="StageManageService" type="JiJingTaekwondo.MatchService.StageManageService,JiJingTaekwondo"/>
      <typeAlias alias="IFlagMatchService" type="JiJingTaekwondo.IMatchService.IFlagMatchService,JiJingTaekwondo"/>
      <typeAlias alias="FlagMatchService" type="JiJingTaekwondo.MatchService.FlagMatchService,JiJingTaekwondo"/>
      <typeAlias alias="IContestWeightManage" type="JiJingTaekwondo.IMatchService.IContestWeightManage,JiJingTaekwondo"/>
      <typeAlias alias="ContestWeightManage" type="JiJingTaekwondo.MatchService.ContestWeightManage,JiJingTaekwondo"/>
      <!--<typeAlias alias="AthleteInfoService" type="JiJingTaekwondoDataCore.DataService.AthleteInfoService,JiJingTaekwondo.Data.Core" />
        <typeAlias alias="IAthleteInfoService" type="JiJingTaekwondoDataCore.IDataService.IAthleteInfoService,JiJingTaekwondo.Data.Core" />-->
    </typeAliases>
    <containers>
      <!--MyContainer为自定义名称 只需要和调用时名称保持一致即可-->
      <container name="MyContainer">
        <types>
          <type type="IAthleteService" mapTo="AthleteService"/>
          <type type="IMatchPortPara" mapTo="MatchPortPara"/>
          <type type="IMatchManagerService" mapTo="MatchManagerService"/>
          <type type="IFunctionManagerService" mapTo="FunctionManagerService"/>
          <type type="IMatchResultService" mapTo="MatchResultService"/>
          <type type="lMatchService" mapTo="MatchService"/>
          <type type="IStageManageService" mapTo="StageManageService"/>
          <type type="IFlagMatchService" mapTo="FlagMatchService"/>
          <type type="IContestWeightManage" mapTo="ContestWeightManage"/>
        </types>
        <!--type为对象的名称,mapTo为注入对象的名称 写法为用逗号隔开两部分，一是类的全部，包括命名空间，二是程序集名称-->
        <!--<register type="JiJingTaekwondo.IMatchService.IAtce,hleteServiJiJingTaekwondo" mapTo="JiJingTaekwondo.MatchService.AthleteService,JiJingTaekwondo">
              <lifetime type="singleton" />
          </register>-->
        <!--<register type="JiJingTaekwondo.Data.Core.IDataService.IAthleteInfoService,JiJingTaekwondo.Data.Core" mapTo="JiJingTaekwondo.Data.Core.DataService.AthleteInfoService,JiJingTaekwondo.Data.Core">
              
          </register>-->
      </container>
    </containers>
  </unity>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <appSettings>
	  
	<add key="xuzuo" value="False"/>
	<add key="TeachEffective" value="1D"/>
	<add key="PunchEffective" value="2"/>
	<add key="PunchValue" value="6"/>
	<add key="PunchMode" value="2"/>
	<add key="JudgeAlarm" value="0"/>
	<add key="MatchClassification" value="0"/>
    <add key="UsePunch" value="0"/>
	<add key="UseDoubleGamJeom" value="0"/>
	<add key="DataProtocolSupplier" value="0"/>
	<add key="ShowTestModeHitLevel" value="1"/>
	<add key="UseShowHitLevelOnlyTrunk" value="0"/>
	
    <!--设置屏幕参数，|||EnableSetScreen = 0，开启手动配置||| ScreenWidth ScreenHeight 屏幕分辨率 此处给出典型值1920*1080-->
    <add key="EnableSetScreen" value="0"/>
    <add key="ScreenWidth" value="1920"/>
    <add key="ScreenHeight" value="1080"/>
    <add key="CheckHeartTimerInterval" value="8"/>
    <add key="HeartTimerInterval" value="16"/>
    <!--<add key="EnableSetScreen" value="0"/>
    <add key="ScreenWidth" value="1280"/>
    <add key="ScreenHeight" value="750"/>-->
    <!--<add key="CheckHeartTimerInterval" value="3"/>
    <add key="HeartTimerInterval" value="16"/>-->
    <add key="CurrentLanguage" value="ZH"/>
    <add key="UpdateUrl" value="http://..."/>
    <add key="Title" value="Jijin_v1.1.4"/>
    <add key="Version" value="v1.1.4"/>
    <add key="bodyLevel" value="0"/>
    <add key="headLevel" value="0"/>
    <add key="UpdateDesc" value="null"/>
    <!--比赛日志的存储级别,0全部保存,1只保存读到卡号的数据-->
    <add key="matchLogWriteLevel" value="0"/>
    <!--比赛日志的读取,0全部读取,1只读取读到卡号的数据-->
    <add key="matchLogReadLevel" value="1"/>
    <!--是否启用登陆界面,true启用,false禁用-->
    <add key="IsEnableLoginWindow_login" value="true"/>
    <add key="IsNetWorkVersion" value="false"/>
    <!--语言-->
    <add key="Language1" value="ZH"/>
    <add key="Language2" value="English"/>
    <add key="Language3" value="KO"/>
	<add key="Language4" value="ES"/>
    <add key="DeviceNumberCount" value="8"/>
    <add key="LoginUrl_login" value="https://d.jijinsport.com/we/product/login"/>
    <add key="LoginUrl_code" value="https://d.jijinsport.com/we/product/sendMess"/>
    <add key="LoginUrl_newPwd" value="https://d.jijinsport.com/we/product/updatePassword"/>
    <add key="DeviceActivation_url" value="https://d.jijinsport.com/we/product/updateActiveType"/>
    <add key="UpLoadingUrl_url" value="http://d.jijinsport.com:10090/we/match/data"/>
    <add key="UpdatePssUrl_url" value="http://yun1.seagetech.com:50021"/>
    <add key="GetMac_url" value="http://d.jijinsport.com:10090/qrcode/mac"/>
    <add key="ClientSettingsProvider.ServiceUri" value=""/>
    <add key="IsReceiverOnline" value="1"/>
    <add key="MacUrlLength" value="30"/>
	<add key="EnableHitValue" value="0"/>
	<add key="MatchGetWay" value="0"/>
	<add key="MatchGetWayOvrPath" value=""/>
  </appSettings>
  <userSettings>
